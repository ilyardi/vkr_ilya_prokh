<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="minimum-scale=1, initial-scale=1, width=device-width, shrink-to-fit=no" />
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js"></script>
    <script src="https://static.cdn.integros.com/player/latest/integros_player.js"></script>
    <title>Канал <%= @channel.name %></title>
    <style>
      body {
        padding: 0px;
        margin: 0px;
      }
    </style>
</head>
<body>
    <div id="video_player"></div>
    <script>
      (function() {
        var id = "video_player";
        var playerOptions = {
            title: "<%= @channel.name %>",
            width: '100%',
            height: '100%',
            aspect_ratio: '16:9',
            live: true,
        };

        Integros.Player.create(id, {"hls": '<%= @channel.video_url %>'}, playerOptions);
      })();
    </script>
</body>
</html>
